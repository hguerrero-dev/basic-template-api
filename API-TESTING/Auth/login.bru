meta {
  name: login
  type: http
  seq: 1
}

post {
  url: {{base_url}}auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "username": "hguerrero",
    "password": "12345678"
  }
}

script:post-response {
  // Verificamos que el login fue exitoso (status 200)
  if (res.status === 200) {
      const token = res.body.data.token;
      bru.setEnvVar("token", token);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
